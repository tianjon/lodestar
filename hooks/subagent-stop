#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
# shellcheck source=hooks/lib.sh
source "$SCRIPT_DIR/lib.sh"

root="$(project_root)"

if [ ! -d "$root/.lodestar" ]; then
  exit 0
fi

emit_system_message "Lodestar: capture the subagent return into the parent context as state, evidence, decision, GAP, and next-action updates before losing the handoff."
