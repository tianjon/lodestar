#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
# shellcheck source=hooks/lib.sh
source "$SCRIPT_DIR/lib.sh"

root="$(project_root)"
state_dir="$root/.lodestar"

if [ ! -d "$state_dir" ]; then
  exit 0
fi

context="$(cat <<EOF
<LODESTAR_DRIFT_CHECK>
Before this mutating/non-trivial tool call, silently compare the action with the active Anchor.
Proceed when it advances Done-when or a named GAP. If it is a productive tangent, preserve a
Return-stack entry. If it drifts, surface the mismatch before continuing.

$(file_excerpt "ANCHOR" "$state_dir/anchor.md" 50)
</LODESTAR_DRIFT_CHECK>
EOF
)"

emit_additional_context "PreToolUse" "$context"
