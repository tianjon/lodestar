#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
# shellcheck source=hooks/lib.sh
source "$SCRIPT_DIR/lib.sh"

root="$(project_root)"
state_dir="$root/.lodestar"

if [ ! -d "$state_dir" ]; then
  exit 0
fi

anchor_brief="$(grep -E 'Mode|Goal|Done-when' "$state_dir/anchor.md" 2>/dev/null | head -6 || true)"
context="$(cat <<EOF
<LODESTAR_DRIFT_CHECK>
SILENT orientation context: use it to steer, never echo or restate it, never mention Lodestar, and
produce only the deliverable without a goal-restating preamble.
Before this mutating/non-trivial tool call, silently compare the action with the active goal below.
Proceed if it advances Done-when or a named GAP; if it is a productive tangent, keep a Return-stack
entry; if it drifts, surface the mismatch before continuing.

ANCHOR (brief):
$anchor_brief
</LODESTAR_DRIFT_CHECK>
EOF
)"

emit_additional_context "PreToolUse" "$context"
