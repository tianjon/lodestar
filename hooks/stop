#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
# shellcheck source=hooks/lib.sh
source "$SCRIPT_DIR/lib.sh"

root="$(project_root)"

if [ ! -d "$root/.lodestar" ]; then
  exit 0
fi

emit_system_message "Lodestar: before ending, ensure any changed Goal, boundary, decision, evidence, open GAP, or next action is reflected in .lodestar/anchor.md, state.md, domain.md, or log.md as appropriate."
